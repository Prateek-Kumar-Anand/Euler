{
  "manifest_version": 3,
  "name": "DataGrapher — Smart Data Extractor",
  "version": "1.0.0",
  "description": "Extract numeric data from any webpage and visualise it as Bar, Line, or Pie charts — fully offline.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DataGrapher",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
